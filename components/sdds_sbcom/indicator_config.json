{
    "view": {
        "state-success": {
            "props": {
                "backgroundColor": {
                    "type": "color",
                    "default": "text.default.positive"
                }
            },
            "binding": [
                {
                    "name": "state",
                    "value": "success"
                }
            ]
        },
        "state-global-white": {
            "props": {
                "backgroundColor": {
                    "type": "color",
                    "default": "surface.default.solid-primary"
                }
            },
            "binding": [
                {
                    "name": "state",
                    "value": "global-white"
                }
            ]
        },
        "state-mute": {
            "props": {
                "backgroundColor": {
                    "type": "color",
                    "default": "text.default.paragraph"
                }
            },
            "binding": [
                {
                    "name": "state",
                    "value": "mute"
                }
            ]
        },
        "state-danger": {
            "props": {
                "backgroundColor": {
                    "type": "color",
                    "default": "text.default.negative"
                }
            },
            "binding": [
                {
                    "name": "state",
                    "value": "danger"
                }
            ]
        },
        "state-warning": {
            "props": {
                "backgroundColor": {
                    "type": "color",
                    "default": "text.default.warning"
                }
            },
            "binding": [
                {
                    "name": "state",
                    "value": "warning"
                }
            ]
        }
    },
    "props": {
        "shape": {
            "type": "shape",
            "value": "round.circle"
        },
        "width": {
            "type": "dimension",
            "value": 8
        },
        "height": {
            "type": "dimension",
            "value": 8
        }
    },
    "bindings": [
        {
            "name": "state",
            "type": "enum",
            "values": [
                "success",
                "global-white",
                "mute",
                "danger",
                "warning"
            ],
            "defaultValue": "success"
        }
    ],
    "variations": []
}
