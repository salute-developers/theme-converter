{
    "view": {
        "active": {
            "props": {
                "backgroundColor": {
                    "type": "color",
                    "default": "surface.default.positive"
                }
            },
            "binding": [
                {
                    "name": "view",
                    "value": "active"
                }
            ]
        },
        "inactive": {
            "props": {
                "backgroundColor": {
                    "type": "color",
                    "default": "surface.on-light.solid-tertiary"
                }
            },
            "binding": [
                {
                    "name": "view",
                    "value": "inactive"
                }
            ]
        }
    },
    "props": {
        "shape": {
            "type": "shape",
            "value": "round.circle"
        }
    },
    "bindings": [
        {
            "name": "size",
            "type": "enum",
            "values": [
                "l",
                "m",
                "s"
            ],
            "defaultValue": "l"
        },
        {
            "name": "view",
            "type": "view",
            "values": [
                "active",
                "inactive"
            ],
            "defaultValue": "active"
        }
    ],
    "variations": [
        {
            "id": "l",
            "parent": null,
            "props": {
                "width": {
                    "type": "dimension",
                    "value": 12
                },
                "height": {
                    "type": "dimension",
                    "value": 12
                }
            },
            "binding": [
                {
                    "name": "size",
                    "value": "l"
                }
            ]
        },
        {
            "id": "m",
            "parent": null,
            "props": {
                "width": {
                    "type": "dimension",
                    "value": 8
                },
                "height": {
                    "type": "dimension",
                    "value": 8
                }
            },
            "binding": [
                {
                    "name": "size",
                    "value": "m"
                }
            ]
        },
        {
            "id": "s",
            "parent": null,
            "props": {
                "width": {
                    "type": "dimension",
                    "value": 6
                },
                "height": {
                    "type": "dimension",
                    "value": 6
                }
            },
            "binding": [
                {
                    "name": "size",
                    "value": "s"
                }
            ]
        }
    ]
}
